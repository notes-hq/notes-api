# HTTP-сервер backend.
# Эти же HOST и PORT используются служебными CLI-утилитами,
# если API_BASE_URL не задан явно.
PORT=3000
HOST=127.0.0.1

# Подключение к MySQL.
# Значения нужно заменить под свою локальную или серверную среду.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=notes_db
